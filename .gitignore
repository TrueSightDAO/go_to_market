# Virtual Environment
venv/
env/
ENV/

# --- Credentials & secrets (never commit) ---
# Do not use blanket *.json here — this repo has legitimate JSON (data, Node configs).
# Add new filenames if you introduce another local secret file.

# Google Cloud: Sheets/Drive service account used by scripts
google_credentials.json
google_credentials*.json
**/google_credentials.json

# OAuth / API tokens under credentials/ (Search Console, Gmail, etc.)
# Ignore the whole tree; only allow per-folder README + .gitignore in git.
credentials/**
!credentials/**/
!credentials/**/README.md
!credentials/**/.gitignore

# OAuth client JSON may also live outside credentials/
**/client_secret*.json

# OAuth token / authorized-user exports (any folder — easy to drop beside a script)
**/token.json
**/authorized_user.json

# Clasp user login (normally ~/.clasprc.json; ignore if copied into repo)
.clasprc.json
**/.clasprc.json

# Private keys / signing material
*.key
*.p8

# Other service account / key JSON naming
service_account.json
*service_account*.json
**/*service-account*.json
# Broad catch for ad-hoc Google key downloads; review before adding similarly named non-secret JSON
*credentials*.json

# Environment and API keys
.env
.env.*
!.env.example

# Key material
*.pem
*.p12
*.pfx

# Google auth legacy / ADC paths sometimes copied by mistake
token.pickle
**/token.pickle
**/application_default_credentials.json
.gcloud/

# GitHub Actions secret prep / exports
github_secret_credentials.txt
**/token_export*.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp

# Office application lock files
.~lock.*

# Feedback processing files
community_feedback.csv

# Raw data folders
**/raw/
raw/
online_content/agroverse_shop/**/raw/

# Local Hit List exports / Place Photo cache (do not commit)
data/hit_list.csv
data/hit_list.csv.backup_*
data/place_photos/

# Node.js
node_modules/
npm-debug.log*
yarn-error.log
.npm
.yarn

# OpenClaw: repo folder is docs-only — never commit ~/.openclaw exports dropped here
openclaw/*
!openclaw/README.md
!openclaw/.gitignore
!openclaw/.nvmrc
