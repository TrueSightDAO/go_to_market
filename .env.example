# Copy to `.env` and fill in locally (never commit `.env`).
#   cp .env.example .env
#
# See `README.md` (GitHub PAT) and `SECURITY.md`.
#
# AWS account / incident-response credentials belong in the sibling repo
# `Cypher-Defense/.env` (gitignored there). EC2 cleanup helpers live under
# `Cypher-Defense/scripts/aws/` (see that repo's README).

# GitHub Personal Access Token — optional but required for automations that upload
# invoice PDFs to TrueSightDAO/.github `assets/` (Contribution Ledger workflow) or for
# `gh` CLI with `GH_TOKEN` if your token includes pull request scopes.
# Create at: https://github.com/settings/tokens (classic: repo scope for private needs;
# fine-grained: Contents read/write on TrueSightDAO/.github; add Pull requests read/write
# if you use this token for `gh pr create` / merge).
GITHUB_PAT=

# Optional: Google Maps / Places API key for `scripts/google_places_lookup.py`.
# The browser key in `agroverse_shop/js/config.js` is often referrer-locked and will NOT work from Python on localhost.
# Prefer a separate key in Google Cloud → APIs & Services → Credentials → Create key → Application restriction: IP addresses (your machine/VPN).
GOOGLE_MAPS_API_KEY=

# xAI Grok — optional locally; required for scripts/hit_list_research_photo_review.py (vision model).
GROK_API_KEY=

# Google Gemini (AI Studio API key) — optional; used by scripts/hit_list_extract_email_gemini.py
# Create: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
